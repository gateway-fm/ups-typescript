{
  "name": "@gatewayfm/sdk-monorepo",
  "private": true,
  "version": "0.0.22",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gateway-fm/ups-typescript.git"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "generate:types": "openapi-typescript api/swagger.yaml -o api/generated/api-types.ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm --filter @gatewayfm/sdk test:e2e",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "clean": "rm -rf node_modules packages/*/dist packages/*/node_modules",
    "prepublishOnly": "pnpm build && pnpm test",
    "release": "pnpm version && git push --follow-tags"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "msw": "^2.13.6",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
